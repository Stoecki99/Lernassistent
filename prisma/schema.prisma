// Prisma Schema für Lernassistent
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Gamification & Streak
  streak        Int       @default(0)
  longestStreak Int       @default(0)
  points        Int       @default(0)
  lastStudyDate DateTime?

  // Abo-Modell
  plan              String    @default("free") // "free" | "pro"
  planExpiresAt     DateTime?                  // null = free, Datum fuer Pro
  storageUsedBytes  BigInt    @default(0)      // Speicherverbrauch in Bytes
  apiTokensUsedThisMonth Int  @default(0)      // Claude Token-Verbrauch diesen Monat
  apiUsageResetAt   DateTime  @default(now())  // Monatlicher Reset-Zeitpunkt

  decks         Deck[]
  sessions      Session[]
  accounts      Account[]
  quizResults   QuizResult[]
  chatMessages  ChatMessage[]
  userBadges    UserBadge[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Deck {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#58CC02")
  icon        String   @default("📚")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       Card[]
  quizResults QuizResult[]
}

model Card {
  id        String   @id @default(cuid())
  front     String
  back      String
  hint      String?
  deckId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FSRS Felder
  due           DateTime @default(now())
  stability     Float    @default(0)
  difficulty    Float    @default(0)
  elapsedDays   Int      @default(0)
  scheduledDays Int      @default(0)
  reps          Int      @default(0)
  lapses        Int      @default(0)
  state         Int      @default(0) // 0=New, 1=Learning, 2=Review, 3=Relearning
  lastReview    DateTime?

  deck    Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews Review[]
}

model Review {
  id        String   @id @default(cuid())
  cardId    String
  rating    Int      // 1=Again, 2=Hard, 3=Good, 4=Easy
  duration  Int      @default(0) // Antwortzeit in Sekunden
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model QuizResult {
  id            String   @id @default(cuid())
  userId        String
  deckId        String
  quizType      String   // "multiple_choice" | "true_false" | "free_text"
  totalQuestions Int
  correctAnswers Int
  score         Int      // Verdiente Punkte
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String
  condition   String   @unique // z.B. "first_card", "streak_7"
  points      Int      @default(0)
  createdAt   DateTime @default(now())

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}
