# =============================================================================
# Lernassistent — Environment Variables
# Copy to .env and fill in real values before deployment
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_secure_password_here
POSTGRES_DB=lernassistent

# --- Database URL (used by Prisma & the app) ---
# For local development:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lernassistent"
# For Docker (overridden in docker-compose.yml):
# DATABASE_URL="postgresql://postgres:PASSWORD@db:5432/lernassistent"

# --- NextAuth.js ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand"
# Local:
NEXTAUTH_URL="http://localhost:3000"
# Production:
# NEXTAUTH_URL="https://lernen.jan-stocker.cloud"

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY="sk-ant-api-CHANGE_ME"

# --- Deployment (used by init-letsencrypt.sh) ---
DOMAIN=lernen.jan-stocker.cloud
EMAIL=jan@jan-stocker.cloud
