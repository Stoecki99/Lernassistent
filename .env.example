# =============================================================================
# Lernassistent — Environment Variables
# Copy to .env and fill in real values before deployment
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_secure_password_here
POSTGRES_DB=lernassistent

# --- NextAuth.js ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-api-CHANGE_ME

# --- Admin Panel ---
ADMIN_EMAIL=deine-email@example.com
